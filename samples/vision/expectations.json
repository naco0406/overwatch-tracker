      "purpose": ["live_map_recommendation"],
      "expected": {
        "mapCandidates": [
          {
            "mapId": "ilios",
            "label": "일리오스"
          },
          {
            "mapId": "runasapi",
            "label": "루나사피"
          },
          {
            "mapId": "paraiso",
            "label": "파라이수"
          }
